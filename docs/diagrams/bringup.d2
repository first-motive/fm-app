# What fm_bringup composes, with the nodes each layer spawns. Description is the
# foundation; control sits on it; manual (teleop) and autonomy (auto) layer on
# control; all command paths reach the hardware boundary. Each block: human label
# (role), package, then nodes. The Hardware Boundary is abstract (dashed) —
# expanded in hardware.d2.
...@styles
direction: right

desc: "" {
  grid-rows: 4
  class: block
  r: Description { class: role }
  p: fm_description { class: pkg }
  a1: robot_state_publisher { class: art }
  a2: joint_state_publisher { class: art }
}
control: "" {
  grid-rows: 4
  class: block
  r: Control { class: role }
  p: fm_control { class: pkg }
  a1: controller_manager { class: art }
  a2: controllers { class: art }
}
manual: "" {
  grid-rows: 4
  class: block
  r: Manual { class: role }
  p: fm_teleop { class: pkg }
  a1: moveit_servo { class: art }
  a2: input adapter { class: art }
}
auto: "" {
  grid-rows: 2
  class: block
  r: Auto { class: role }
  p: learning overlay · private { class: pkg }
}
boundary: "" {
  grid-rows: 2
  class: zoom
  r: Hardware Boundary { class: role }
  a: sim_backend { class: art }
}

desc -> control
control -> manual
control -> auto
control -> boundary
manual -> boundary: commands
auto -> boundary: commands
